    { "source": "/login",          "destination": "/email_job-main/bulk-mailer/login.html" },
    { "source": "/send",           "destination": "/email_job-main/bulk-mailer/send.html" },
    { "source": "/profile",        "destination": "/email_job-main/bulk-mailer/profile.html" },
    { "source": "/template",       "destination": "/email_job-main/bulk-mailer/template.html" },
    { "source": "/whatsapp",       "destination": "/email_job-main/bulk-mailer/whatsapp.html" },
    { "source": "/whatsapp-logs",  "destination": "/email_job-main/bulk-mailer/whatsapp_logs.html" },
