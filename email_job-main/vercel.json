{
  "rewrites": [
    { "source": "/",                "destination": "/bulk-mailer/index.html" },
    { "source": "/login",           "destination": "/bulk-mailer/login.html" },
    { "source": "/pricing",         "destination": "/bulk-mailer/pricing.html" },
    { "source": "/send",            "destination": "/bulk-mailer/send.html" },
    { "source": "/profile",         "destination": "/bulk-mailer/profile.html" },
    { "source": "/template",        "destination": "/bulk-mailer/template.html" },
    { "source": "/whatsapp",        "destination": "/bulk-mailer/whatsapp.html" },
    { "source": "/whatsapp-logs",   "destination": "/bulk-mailer/whatsapp_logs.html" },
    { "source": "/jobs",            "destination": "/bulk-mailer/jobs.html" },
    { "source": "/(.*\\.html)",     "destination": "/bulk-mailer/$1" },
    { "source": "/(.*\\.(js|css|png|jpg|ico|json|svg|woff|woff2|ttf|pdf|webmanifest))", "destination": "/bulk-mailer/$1" }
  ]
}
